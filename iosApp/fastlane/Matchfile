git_url(ENV.fetch("MATCH_GIT_URL"))
storage_mode("git")
type("appstore")
readonly(true)
team_id(ENV.fetch("APPLE_TEAM_ID"))

if ENV["MATCH_GIT_BRANCH"] && !ENV["MATCH_GIT_BRANCH"].empty?
  git_branch(ENV["MATCH_GIT_BRANCH"])
end

if ENV["APP_BUNDLE_ID"] && !ENV["APP_BUNDLE_ID"].empty?
  app_identifier([ENV["APP_BUNDLE_ID"]])
end
